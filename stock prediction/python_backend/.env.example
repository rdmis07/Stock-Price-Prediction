# ── Application ─────────────────────────────────────────
APP_NAME=QuantumStock
APP_ENV=development
DEBUG=true

# ── Database ────────────────────────────────────────────
DATABASE_URL=sqlite:///./quantumstock.db
# DATABASE_URL=postgresql+psycopg2://quantum:secret@localhost:5432/quantumstock

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-very-long-random-string-please
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=1440

# ── Email (alerts) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=alerts@quantumstock.io

# ── ML ──────────────────────────────────────────────────
MODEL_DIR=./saved_models
DATASET_DIR=./datasets
DEFAULT_HORIZON=30
RETRAIN_INTERVAL_HOURS=168
